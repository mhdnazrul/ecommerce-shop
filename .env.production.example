# ──────────────────────────────────────────────────────────────────────────────
# Shopfinity — Production Environment Variables
# Copy this to .env.production and fill in your production values.
# NEVER commit the actual .env.production file.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Database (Neon PostgreSQL) ──────────────────────────────────────────────
# Pooled connection (use ?pgbouncer=true for serverless):
DATABASE_URL=postgresql://user:password@ep-example-xxx.us-east-2.aws.neon.tech/db?sslmode=require&pgbouncer=true
# Direct connection for migrations (no pooler):
DIRECT_URL=postgresql://user:password@ep-example-xxx.us-east-2.aws.neon.tech/db?sslmode=require

# ─── NextAuth v5 ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-32-char-production-secret
# MUST match your Vercel deployment domain:
AUTH_URL=https://shopfinity.vercel.app

# ─── Google OAuth ────────────────────────────────────────────────────────────
# https://console.cloud.google.com/apis/credentials
# Add authorized redirect URI: https://shopfinity.vercel.app/api/auth/callback/google
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# ─── Cloudinary ──────────────────────────────────────────────────────────────
# https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-production-cloud-name
CLOUDINARY_API_KEY=your-production-api-key
CLOUDINARY_API_SECRET=your-production-api-secret

# ─── Resend ──────────────────────────────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
# Must be a verified domain in Resend:
EMAIL_FROM=noreply@yourdomain.com

# ─── Stripe ──────────────────────────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys — switch to Live keys
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
# Public key (safe to expose to client):
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxx

# ─── Sentry ──────────────────────────────────────────────────────────────────
# https://sentry.io/settings/projects
SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@xxxxxxxxx.ingest.sentry.io/xxxxxx
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=shopfinity

# ─── App URL ─────────────────────────────────────────────────────────────────
# Used for sitemap, OG tags, webhook callbacks:
NEXT_PUBLIC_APP_URL=https://shopfinity.vercel.app
